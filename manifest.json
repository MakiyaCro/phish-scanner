{
  "manifest_version": 3,
  "name": "PHISH.Scanner",
  "version": "1.1",
  "description": "Scans Gmail emails for phishing indicators",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["https://mail.google.com/*"],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "16.png",
      "48": "48.png",
      "128": "128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
